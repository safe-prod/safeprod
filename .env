## AI - Vercel AI Gateway:
## - If running locally, paste your Vercel AI Gateway API key here.
## - The value of the embedding model key has to be a string referring to your chosen Vercel AI Gateway model. Go to the Vercel AI Gateway website to copy the string for your chosen model.

# AI_GATEWAY_API_KEY=
# NEXT_PUBLIC_EMBEDDING_MODEL=

## Database - Supabase:
## - If running locally, paste your Supabase variables here.
## - Paste the variables inside the double quotes.

# POSTGRES_URL=""
# POSTGRES_USER=""
# POSTGRES_HOST=""
# SUPABASE_JWT_SECRET=""
# NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# POSTGRES_PRISMA_URL=""
# POSTGRES_PASSWORD=""
# POSTGRES_DATABASE=""
# SUPABASE_URL=""
# NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# NEXT_PUBLIC_SUPABASE_URL=""
# SUPABASE_SERVICE_ROLE_KEY=""
# POSTGRES_URL_NON_POOLING=""
